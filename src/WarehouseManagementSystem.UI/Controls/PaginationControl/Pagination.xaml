<UserControl
    x:Class="WarehouseManagementSystem.UI.Controls.Pagination"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Controls"
    x:Name="PageControl">

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <local:SolidButton
            Height="34"
            Padding="8,0,1,0"
            Background="Transparent"
            HoverBackground="{StaticResource Green}"
            CornerRadius="8"
            Text=""
            IconColor="{StaticResource LightGray}"
            HoverIconColor="{StaticResource White}"
            LeftIcon="pack://application:,,,/Resources/Icons/prev.png"
            Command="{Binding RelativeSource={RelativeSource AncestorType=local:Pagination}, Path=PrevPageCommand}" />

        <ItemsControl ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=local:Pagination}, Path=PageItems}" UseLayoutRounding="True">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="local:PageItem">
                    <Grid Margin="2,0">
                        <Button
                            Name="PageButton"
                            Height="36"
                            MinWidth="36"
                            Cursor="Hand"
                            FontSize="14"
                            Content="{Binding DisplayText}"
                            Command="{Binding RelativeSource={RelativeSource AncestorType=local:Pagination}, Path=GoToPageCommand}"
                            CommandParameter="{Binding PageNumber}" >

                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="Foreground" Value="{StaticResource LightGray}"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" 
                                                    Background="{TemplateBinding Background}" 
                                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                                    BorderThickness="1" 
                                                    CornerRadius="8" 
                                                    SnapsToDevicePixels="true">

                                                    <ContentPresenter x:Name="contentPresenter" 
                                                        HorizontalAlignment="Center" 
                                                        VerticalAlignment="Center" 
                                                        Focusable="False"
                                                        SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="true">
                                                        <Setter TargetName="border" Property="Background" Value="{StaticResource Green}"/>
                                                        <Setter Property="Foreground" Value="{StaticResource White}" />
                                                        <Setter Property="Opacity" Value="0.9" />
                                                    </Trigger>

                                                    <Trigger Property="IsPressed" Value="true">
                                                        <Setter Property="Opacity" Value="1" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>

                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource Green}"/>
                                            <Setter Property="Foreground" Value="{StaticResource White}"/>
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <TextBlock
                            Name="EllipsisText" 
                            Text="{Binding DisplayText}" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Center" 
                            Padding="6,0"
                            Visibility="Collapsed"/>
                    </Grid>

                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding PageNumber}" Value="{x:Null}">
                            <Setter TargetName="PageButton" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="EllipsisText" Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <local:SolidButton
            Height="34"
            Padding="9,0,0,0"
            Background="Transparent"
            HoverBackground="{StaticResource Green}"
            CornerRadius="8"
            Text=""
            IconColor="{StaticResource LightGray}"
            HoverIconColor="{StaticResource White}"
            LeftIcon="pack://application:,,,/Resources/Icons/next.png"
            Command="{Binding RelativeSource={RelativeSource AncestorType=local:Pagination}, Path=NextPageCommand}" />

    </StackPanel>
</UserControl>