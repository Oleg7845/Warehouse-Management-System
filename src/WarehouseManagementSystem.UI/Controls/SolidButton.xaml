<Button
    x:Class="WarehouseManagementSystem.UI.Controls.SolidButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:WarehouseManagementSystem.UI.Converters"
    Foreground="White" 
    BorderThickness="0" 
    Cursor="Hand"
    HorizontalAlignment="Center">

    <Button.Resources>
        <conv:NullFallbackConverter x:Key="NullFallbackConverter"/>
    </Button.Resources>

    <Button.Template>
        <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="mainBorder" 
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}}"
                    SnapsToDevicePixels="True">

                <Grid>
                    <Border x:Name="hoverLayer" 
                            Background="{Binding HoverBackground, RelativeSource={RelativeSource TemplatedParent}}" 
                            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}}" 
                            Opacity="0"/>

                    <Border x:Name="pressedLayer" 
                            Background="{Binding PressedBackground, RelativeSource={RelativeSource TemplatedParent}}" 
                            CornerRadius="{Binding CornerRadius, RelativeSource={RelativeSource TemplatedParent}}" 
                            Opacity="0"/>

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="{TemplateBinding Padding}"
                        HorizontalAlignment="{Binding InnerOrientation, RelativeSource={RelativeSource TemplatedParent}}">

                        <Grid x:Name="LeftIconHost" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding LeftIcon, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <Border x:Name="leftIconBorder" Width="16" Height="16" 
                                    Background="{Binding IconColor, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IconColor, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="{Binding LeftIcon, RelativeSource={RelativeSource TemplatedParent}}" Stretch="Uniform"/>
                                </Border.OpacityMask>
                            </Border>
                        </Grid>

                        <TextBlock x:Name="btnText"
                                   Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}}"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   VerticalAlignment="Center"/>

                        <Grid x:Name="RightIconHost" Margin="8,0,0,0" VerticalAlignment="Center">
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RightIcon, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Border x:Name="rightIconBorder" Width="16" Height="16" 
                                    Background="{Binding IconColor, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RightIcon, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IconColor, RelativeSource={RelativeSource TemplatedParent}}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.OpacityMask>
                                    <ImageBrush ImageSource="{Binding RightIcon, RelativeSource={RelativeSource TemplatedParent}}" Stretch="Uniform"/>
                                </Border.OpacityMask>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="hoverLayer" Property="Opacity" Value="1"/>
                    <Setter TargetName="mainBorder" Property="Opacity" Value="0.9"/>

                    <Setter TargetName="btnText" Property="Foreground">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource NullFallbackConverter}">
                                <Binding Path="HoverForeground" RelativeSource="{RelativeSource TemplatedParent}"/>
                                <Binding Path="Foreground" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>

                    <Setter TargetName="leftIconBorder" Property="Background">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource NullFallbackConverter}">
                                <Binding Path="HoverIconColor" RelativeSource="{RelativeSource TemplatedParent}"/>
                                <Binding Path="IconColor" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>

                    <Setter TargetName="rightIconBorder" Property="Background">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource NullFallbackConverter}">
                                <Binding Path="HoverIconColor" RelativeSource="{RelativeSource TemplatedParent}"/>
                                <Binding Path="IconColor" RelativeSource="{RelativeSource TemplatedParent}"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Trigger>

                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="pressedLayer" Property="Opacity" Value="1"/>
                    <Setter TargetName="mainBorder" Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                        </Setter.Value>
                    </Setter>
                    <Setter TargetName="mainBorder" Property="RenderTransformOrigin" Value="0.5,0.5"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
    </Button.Template>
</Button>