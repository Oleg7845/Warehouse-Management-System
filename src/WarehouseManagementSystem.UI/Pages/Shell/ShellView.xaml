<UserControl
    x:Class="WarehouseManagementSystem.UI.Pages.Shell.ShellView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.Shell"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:user_create="clr-namespace:WarehouseManagementSystem.UI.Pages.Users.UserCreate"
    xmlns:user_view="clr-namespace:WarehouseManagementSystem.UI.Pages.Users.UserView"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    xmlns:conv="clr-namespace:WarehouseManagementSystem.UI.Converters"
    mc:Ignorable="d"
    Background="{StaticResource White}">

    <UserControl.Resources>
        <DataTemplate DataType="{x:Type user_create:UserCreateViewModel}">
            <user_create:UserCreateView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type user_view:UserViewModel}">
            <user_view:UserView />
        </DataTemplate>

        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{StaticResource Green}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="0"
                    Margin="20,5,20,0"
                    BorderBrush="{StaticResource Smoke}"
                    BorderThickness="0,0,0,1">

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,0,0,5">

                        <Image
                            Source="pack://application:,,,/Resources/Icons/logo-box.png"
                            Width="36" 
                            Height="36"
                            Margin="0,0,15,0" />

                    <TextBlock
                        MaxWidth="200"
                        Margin="0,10,0,10"
                        Text="WAREHOUSE MANAGEMENT SYSTEM"
                        TextWrapping="Wrap"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource White}" />
                    </StackPanel>
                </Border>

                <StackPanel
                    Grid.Row="1"
                    Margin="0,0,0,15">

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Dashboard"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/dashboard.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToDashboardCommand}" />

                    <controls:SolidButton
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Support Panel"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/support_panel.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToSupportPanelCommand}" />

                    <controls:SolidButton
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Audit log"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/paper_view.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToAuditLogCommand}" />

                    <controls:SolidButton
                        Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Users"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/users.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToUserListCommand}" />

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Categories"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/category.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToCategoriesCommand}" />

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Products"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/logo-box.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToProductListCommand}" />

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Suppliers"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/archive.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToSuppliersCommand}" />

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Stock operations"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/contract.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToStockOperationsCommand}" />

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Support"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/support.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToSupportCenterCommand}" />

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,0"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Settings"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/settings.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding NavigateToSettingsCommand}" />
                </StackPanel>


                <Border
                    Grid.Row="2"
                    Margin="20,0,20,0"
                    BorderBrush="{StaticResource Smoke}"
                    BorderThickness="0,1,0,0">

                    <controls:SolidButton
                        Width="240"
                        Height="40"
                        Padding="20,0,20,0"
                        Margin="0,5,0,15"
                        FontSize="14"
                        Background="Transparent"
                        HoverBackground="{StaticResource White}"
                        PressedBackground="{StaticResource Smoke}"
                        HoverForeground="{StaticResource Green}"
                        HoverIconColor="{StaticResource Green}"
                        InnerOrientation="Left"
                        CornerRadius="8"
                        Text="Log out"
                        Foreground="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/logout.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding LogoutCommand}" />
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Margin="20,0,20,0"
                BorderBrush="{StaticResource LightGray}"
                BorderThickness="0,0,0,1">

                <TextBlock
                    VerticalAlignment="Center"
                    Text="{Binding PageTitle}"
                    FontSize="20"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource Gray}" />
            </Border>

            <ContentControl
                Grid.Row="1"
                Margin="20,15,20,20"
                Content="{Binding CurrentView}" />
        </Grid>
    </Grid>
</UserControl>
