<UserControl
    x:Class="WarehouseManagementSystem.UI.Pages.Users.UserCreate.UserCreateView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.Users.UserCreate"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    xmlns:conv="clr-namespace:WarehouseManagementSystem.UI.Converters"
    mc:Ignorable="d" 
    Background="Transparent">

    <UserControl.Resources>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Border
        Padding="20"
        CornerRadius="16"
        ClipToBounds="True"
        Background="{StaticResource White}">

        <Grid
            HorizontalAlignment="Left">

            <StackPanel
                Width="300">

                <TextBlock
                    HorizontalAlignment="Center"
                    Text="Create User"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource Gray}" />

                <controls:TextInput
                    Height="40"
                    Margin="0,20,0,15"
                    Placeholder="Username"
                    LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/user.png"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <controls:SelectInput
                    Height="40"
                    Margin="0,0,0,15"
                    ItemsSource="{Binding AvailableRoles}"
                    SelectedItem="{Binding SelectedRole}"
                    Placeholder="Role"
                    LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/users.png" />

                <StackPanel
                    Orientation="Horizontal"
                    Width="300"
                    Margin="0,0,0,20">

                    <controls:TextInput
                        Width="250"
                        Height="40"
                        Placeholder="Password"
                        IsPasswordMode="True"
                        LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/padlock.png"
                        Text="{Binding Password}" />

                    <controls:SolidButton
                        Width="40"
                        Height="40"
                        Margin="10,0,0,0"
                        Padding="7,0,0,0"
                        FontSize="14"
                        Background="{StaticResource LightGray}"
                        CornerRadius="8"
                        Text=""
                        ToolTip="Generate password"
                        LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/refresh.png"
                        IconColor="{StaticResource White}"
                        Command="{Binding GeneratePasswordCommand}" />
                </StackPanel>

                <controls:SolidButton
                    Width="300"
                    Height="40"
                    FontSize="14"
                    Background="{StaticResource Green}"
                    CornerRadius="8"
                    Text="Create user"
                    LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/user_plus.png"
                    IconColor="{StaticResource White}"
                    Command="{Binding CreateUserCommand}"
                    IsDefault="True" />

                <controls:SolidButton
                    Visibility="{Binding CopyUserCredentialsButtonVisibility, Converter={StaticResource BooleanToVisibilityConverter}}"
                    Width="300"
                    Height="40"
                    Margin="0,15,0,0"
                    FontSize="14"
                    Foreground="{StaticResource Green}"
                    Background="{StaticResource White}"
                    CornerRadius="8"
                    Text="Copy credentials"
                    LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/copy.png"
                    IconColor="{StaticResource Green}"
                    HoverBackground="{StaticResource Green}"
                    HoverForeground="{StaticResource White}"
                    HoverIconColor="{StaticResource White}"
                    BorderThickness="2"
                    BorderBrush="{StaticResource Green}"
                    Command="{Binding CopyUserCredentialsCommand}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
