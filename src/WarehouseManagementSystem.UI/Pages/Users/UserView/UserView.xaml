<UserControl
    x:Name="Root"
    x:Class="WarehouseManagementSystem.UI.Pages.Users.UserView.UserView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.Users.UserView"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    xmlns:conv="clr-namespace:WarehouseManagementSystem.UI.Converters"
    mc:Ignorable="d" 
    Background="Transparent"
    Width="560">

    <UserControl.Resources>
        <conv:BoolToUserStatusConverter x:Key="BoolToUserStatusConverter" />
        <conv:BoolToSetUserPasswordConverter x:Key="BoolToSetUserPasswordConverter" />
        <conv:BoolToUserLockedConverter x:Key="BoolToUserLockedConverter" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <conv:UtcToLocalConverter x:Key="UtcToLocalConverter" />
    </UserControl.Resources>

    <Border
        Padding="20"
        CornerRadius="16"
        ClipToBounds="True"
        Background="{StaticResource White}">
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="0,0,0,10"
                BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource LightGray}">
                
                <TextBlock
                    HorizontalAlignment="Left"
                    Text="Manage User"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource Gray}" />
            </Border>

            <WrapPanel
                Grid.Row="1"
                Orientation="Horizontal"
                Margin="0,20,0,0">

                <controls:SolidButton
                    Width="160"
                    Height="40"
                    Margin="0,0,20,10"
                    FontSize="14"
                    Background="{StaticResource Green}"
                    CornerRadius="8"
                    Text="Activate"
                    Foreground="{StaticResource White}"
                    IconColor="{StaticResource White}"
                    LeftIcon="pack://application:,,,/Resources/Icons/enable.png"
                    Command="{Binding ActivateUserCommand}" />

                <controls:SolidButton
                    Width="160"
                    Height="40"
                    Margin="0,0,20,10"
                    FontSize="14"
                    Background="{StaticResource Red}"
                    CornerRadius="8"
                    Text="Detivate"
                    Foreground="{StaticResource White}"
                    IconColor="{StaticResource White}"
                    LeftIcon="pack://application:,,,/Resources/Icons/disable.png"
                    Command="{Binding DeactivateUserCommand}" />

                <controls:SolidButton
                    Visibility="Collapsed"
                    Width="160"
                    Height="40"
                    Margin="0,0,20,10"
                    FontSize="14"
                    Background="{StaticResource LightGray}"
                    CornerRadius="8"
                    Text="Change role"
                    Foreground="{StaticResource White}"
                    IconColor="{StaticResource White}"
                    LeftIcon="pack://application:,,,/Resources/Icons/users.png"
                    Command="{Binding ChangeUserRoleCommand}" />

                <controls:SolidButton
                    Width="160"
                    Height="40"
                    Margin="0,0,0,10"
                    FontSize="14"
                    Background="{StaticResource Blue}"
                    CornerRadius="8"
                    Text="Reset attempts"
                    Foreground="{StaticResource White}"
                    IconColor="{StaticResource White}"
                    LeftIcon="pack://application:,,,/Resources/Icons/undo.png"
                    Command="{Binding ResetFailedLoginAttemptsCommand}" />

                <controls:SolidButton
                    Width="160"
                    Height="40"
                    Margin="0,0,20,10"
                    FontSize="14"
                    Background="{StaticResource Purple}"
                    CornerRadius="8"
                    Text="Unlock access"
                    Foreground="{StaticResource White}"
                    IconColor="{StaticResource White}"
                    LeftIcon="pack://application:,,,/Resources/Icons/padlock_open.png"
                    Command="{Binding UnlockUserAccessCommand}" />

                <controls:SolidButton
                    Width="160"
                    Height="40"
                    FontSize="14"
                    Margin="0,0,0,10"
                    Background="{StaticResource Orange}"
                    CornerRadius="8"
                    Text="Reset password"
                    Foreground="{StaticResource White}"
                    IconColor="{StaticResource White}"
                    LeftIcon="pack://application:,,,/Resources/Icons/refresh.png"
                    Command="{Binding ResetUserPasswordCommand}" />
            </WrapPanel>

        <StackPanel
            Grid.Row="2"
            Orientation="Horizontal"
            Margin="0,15,0,0"
            Visibility="{Binding CopyUserCredentialsButtonVisibility, Converter={StaticResource BooleanToVisibilityConverter}}">

            <controls:SolidButton
                Width="300"
                Height="40"
                FontSize="14"
                Foreground="{StaticResource Green}"
                Background="Transparent"
                CornerRadius="8"
                Text="Copy credentials"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/copy.png"
                IconColor="{StaticResource Green}"
                HoverBackground="{StaticResource Green}"
                HoverForeground="{StaticResource White}"
                HoverIconColor="{StaticResource White}"
                BorderThickness="2"
                BorderBrush="{StaticResource Green}"
                Command="{Binding CopyUserCredentialsCommand}" />
        </StackPanel>

        <Border
            Grid.Row="3"
            Margin="0,10,0,0"
            Padding="0,10,0,0"
            BorderThickness="0,1,0,0"
            BorderBrush="{StaticResource LightGray}">
                
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid
                    Grid.Column="0"
                    Margin="0,0,40,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,0,10"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LightGray}"
                        Text="Info" />

                    <StackPanel
                        HorizontalAlignment="Right"
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,20,0">

                        <StackPanel.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Username:" />
                    
                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Role:" />
                    
                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Status:" />
                    
                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Created at:" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1">

                        <StackPanel.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsReadOnly" Value="True"/>
                                <Setter Property="IsTabStop" Value="False"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.Username, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.Role, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.IsActive, Mode=OneWay, Converter={StaticResource BoolToUserStatusConverter}}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.CreatedAt, Mode=OneWay, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}" />
                    </StackPanel>
                </Grid>

                <Grid
                    Grid.Column="1">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,0,10"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LightGray}"
                        Text="Security" />

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        HorizontalAlignment="Right"
                        Margin="0,0,20,0">

                        <StackPanel.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Must change password:" />
                    
                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Locked:" />
                    
                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Login attempts:" />
                    
                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Logged at:" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1">

                        <StackPanel.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsReadOnly" Value="True"/>
                                <Setter Property="IsTabStop" Value="False"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.MustChangePassword, Mode=OneWay, Converter={StaticResource BoolToSetUserPasswordConverter}}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.IsLocked, Mode=OneWay, Converter={StaticResource BoolToUserLockedConverter}}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.FailedLoginAttempts, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentUser.LastLoginAt, Mode=OneWay, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
            <Border
                Grid.Row="4"
                Padding="0,10,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource LightGray}">
                
                <StackPanel
                    HorizontalAlignment="Left">

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="0,0,0,10"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LightGray}"
                        Text="Journals" />

                    <controls:SolidButton
                        HorizontalAlignment="Left"
                        Height="22"
                        Margin="0,0,0,5"
                        Padding="0,2,0,0"
                        FontSize="14"
                        Background="Transparent"
                        LeftIcon="pack://application:,,,/Resources/Icons/paper_view.png"
                        IconColor="{StaticResource LightGray}"
                        Text="{Binding TotalAuditLogs, StringFormat='Audit logs (\{0\})'}"
                        Foreground="{StaticResource Gray}"
                        Command="{Binding OpenUserAuditLogsCommand}" />

                    <controls:SolidButton
                        HorizontalAlignment="Left"
                        Height="22"
                        Padding="0,0,0,2"
                        FontSize="14"
                        Background="Transparent"
                        LeftIcon="pack://application:,,,/Resources/Icons/support.png"
                        IconColor="{StaticResource LightGray}"
                        Text="{Binding TotalSupportTickets, StringFormat='Support tickets (\{0\})'}"
                        Foreground="{StaticResource Gray}"
                        Command="{Binding OpenUserSupportTicketsCommand}" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
