<UserControl
    x:Class="WarehouseManagementSystem.UI.Pages.SupportTickets.SupportTicketList.SupportTicketListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.SupportTickets.SupportTicketList"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    xmlns:conv="clr-namespace:WarehouseManagementSystem.UI.Converters"
    mc:Ignorable="d" 
    Background="{StaticResource White}">

    <UserControl.Resources>
        <conv:UtcToLocalConverter x:Key="UtcToLocalConverter" />
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid
        Grid.Row="0"
        Margin="0,0,0,15">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <controls:TextInput
                Grid.Column="0"
                Width="300"
                Height="40"
                Margin="0,0,20,0"
                Placeholder="Search"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/magnifer.png"
                Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                EnterCommand="{Binding SearchCommand}" />

            <controls:SelectInput
                Grid.Column="1"
                Width="70"
                Height="40"
                Margin="0,0,20,0"
                ItemsSource="{Binding PageSizeOptions}"
                SelectedItem="{Binding PageSize}" />

            <controls:SolidButton
                Grid.Column="2"
                Height="22"
                Background="Transparent"
                Text="Filters"
                FontSize="14"
                Foreground="{StaticResource Gray}"
                IconColor="{StaticResource Gray}"
                RightIcon="{Binding FiltersButtonIcon}"
                Command="{Binding ToggleFiltersCommand}" />

            <controls:SolidButton
                Grid.Column="3"
                Visibility="{Binding IsFiltersUsed, Converter={StaticResource BooleanToVisibilityConverter}}"
                Height="30"
                Width="30"
                Margin="5,0,0,0"
                Padding="8,0,0,0"
                FontSize="14"
                Background="Transparent"
                Text=""
                ToolTip="Clear filters"
                IconColor="{StaticResource Gray}"
                LeftIcon="pack://application:,,,/Resources/Icons/clear_filter.png"
                Command="{Binding ClearFiltersCommand}" />

            <StackPanel
                Grid.Column="4"
                HorizontalAlignment="Right"
                Visibility="{Binding IsUserMode, Converter={StaticResource BooleanToVisibilityConverter}}">

                <controls:SolidButton
                    Width="40"
                    Height="40"
                    Padding="8,0,0,0"
                    FontSize="14"
                    Background="{StaticResource Green}"
                    CornerRadius="8"
                    Text=""
                    ToolTip="Open ticket"
                    Foreground="{StaticResource White}"
                    IconColor="{StaticResource White}"
                    LeftIcon="pack://application:,,,/Resources/Icons/plus.png"
                    Command="{Binding OpenCreateSupportDialogCommand}" />
            </StackPanel>
        </Grid>

        <!-- Floating panel -->
        <Canvas Panel.ZIndex="999">
            <Border
                Width="250"
                Canvas.Left="390"
                Canvas.Top="50"
                Padding="16"
                Background="White"
                BorderBrush="LightGray"
                BorderThickness="1"
                CornerRadius="8"
                Visibility="{Binding IsFiltersOpen, Converter={StaticResource BooleanToVisibilityConverter}}">

                <StackPanel>
                    <controls:SelectInput
                        Height="40"
                        Margin="0,0,0,5"
                        ItemsSource="{Binding AvailableStatuses}"
                        SelectedItem="{Binding SelectedStatus}"
                        Placeholder="Status" />

                    <controls:SelectInput
                        Height="40"
                        Margin="0,0,0,5"
                        ItemsSource="{Binding AvailablePriorities}"
                        SelectedItem="{Binding SelectedPriority}"
                        Placeholder="Priority" />
                </StackPanel>
            </Border>
        </Canvas>

        <DataGrid
            Grid.Row="1"
            HorizontalAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            ItemsSource="{Binding Tickets}"
            SelectedItem="{Binding SelectedTicket}"
            GridLinesVisibility="None"
            HorizontalGridLinesBrush="{StaticResource LightGray}"
            VerticalGridLinesBrush="{StaticResource LightGray}"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            RowHeight="36"
            Background="Transparent"
            BorderThickness="0"
            HeadersVisibility="Column"
            SelectionUnit="Cell"
            ClipboardCopyMode="ExcludeHeader"
            AlternationCount="2"
            RowBackground="{StaticResource DarkSmoke}"
            AlternatingRowBackground="{StaticResource Smoke}">

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <EventSetter
                        Event="MouseDoubleClick"
                        Handler="DataGridRow_MouseDoubleClick"/>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Resources>
                <Style TargetType="ScrollBar">
                    <Setter Property="Width" Value="5"/>
                    <Setter Property="Background" Value="Transparent"/>

                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Background="Transparent">
                                    <Border
                                        Width="5"
                                        CornerRadius="3"
                                        Background="{StaticResource DarkSmoke}">

                                        <Track
                                            Name="PART_Track"
                                            IsDirectionReversed="True">

                                            <Track.DecreaseRepeatButton>
                                                <RepeatButton Opacity="0" />
                                            </Track.DecreaseRepeatButton>

                                            <Track.Thumb>
                                                <Thumb Background="{StaticResource Gray}">
                                                    <Thumb.Template>
                                                        <ControlTemplate TargetType="Thumb">
                                                            <Border
                                                                Width="5"
                                                                Background="{TemplateBinding Background}"
                                                                CornerRadius="3"/>
                                                        </ControlTemplate>
                                                    </Thumb.Template>
                                                </Thumb>
                                            </Track.Thumb>

                                            <Track.IncreaseRepeatButton>
                                                <RepeatButton Opacity="0" />
                                            </Track.IncreaseRepeatButton>
                                        </Track>
                                    </Border>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </DataGrid.Resources>

            <DataGrid.Columns>
                <DataGridTemplateColumn Header="ID" MinWidth="200" Width="350" IsReadOnly="True" ClipboardContentBinding="{Binding PublicId}">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0">

                                <Border
                                    Width="14"
                                    Height="14"
                                    Margin="0,0,8,0"
                                    Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}">

                                    <Border.OpacityMask>
                                        <ImageBrush
                                            ImageSource="pack://application:,,,/Resources/Icons/user.png"
                                            Stretch="Uniform"
                                            RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border.OpacityMask>
                                </Border>

                                <TextBlock
                                    Text="{Binding PublicId}"
                                    VerticalAlignment="Center"
                                    Padding="0,0,0,2"
                                    FontSize="14"
                                    Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>

                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Created by" Binding="{Binding CreatedByUsername}" MinWidth="100" MaxWidth="200" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Title" Binding="{Binding Title}" MinWidth="100" Width="*" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Status" Binding="{Binding Status}" MinWidth="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Priority" Binding="{Binding Priority}" MinWidth="120" IsReadOnly="True">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Header="Closed at"
                    Binding="{Binding ClosedAt, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}"
                    MinWidth="130"
                    IsReadOnly="True">

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Header="Updated at"
                    Binding="{Binding UpdatedAt, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}"
                    MinWidth="130"
                    IsReadOnly="True">

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn
                    Header="Created at"
                    Binding="{Binding CreatedAt, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}"
                    MinWidth="130"
                    IsReadOnly="True">

                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="Margin" Value="10,0"/>
                            <Setter Property="Padding" Value="0,0,0,2"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=DataGridCell}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="{x:Type DataGridColumnHeader}">
                    <Setter Property="Background" Value="{StaticResource LightGray}"/>
                    <Setter Property="Foreground" Value="{StaticResource White}"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>

                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{StaticResource Gray}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                    <Setter Property="Foreground" Value="{StaticResource DarkGray}"/>

                    <Setter Property="BorderBrush" Value="{StaticResource LightGray}"/>

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}" Value="True">
                            <Setter Property="Background" Value="{StaticResource LightGray}"/>
                            <Setter Property="Foreground" Value="{StaticResource White}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>
        </DataGrid>

        <StackPanel
            Grid.Row="2"
            Margin="0,20,0,0"
            HorizontalAlignment="Center">

            <controls:Pagination
                CurrentPage="{Binding CurrentPage}" 
                TotalPages="{Binding TotalPages}"
                MaxVisiblePages="10" />
        </StackPanel>
    </Grid>
</UserControl>
