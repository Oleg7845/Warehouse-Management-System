<UserControl
    x:Class="WarehouseManagementSystem.UI.Pages.SupportTickets.SupportTicketView.SupportTicketView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.SupportTickets.SupportTicketView"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    xmlns:conv="clr-namespace:WarehouseManagementSystem.UI.Converters"
    mc:Ignorable="d" 
    MinWidth="500"
    Width="560">

    <UserControl.Resources>
        <conv:UtcToLocalConverter x:Key="UtcToLocalConverter"/>
        <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Border
        Padding="20"
        CornerRadius="16"
        ClipToBounds="True"
        Background="{StaticResource White}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                Padding="0,0,0,10">

                <TextBlock
                    HorizontalAlignment="Left"
                    Text="View Support Ticket"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource Gray}" />
            </Border>

            <Border Grid.Row="1"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource LightGray}"
                Visibility="{Binding IsTopControlBlockVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                <WrapPanel
                    Orientation="Horizontal">

                    <controls:SolidButton
                        Width="160"
                        Height="40"
                        Margin="0,10,20,10"
                        FontSize="14"
                        Background="{StaticResource Green}"
                        CornerRadius="8"
                        Text="Take ticket"
                        Foreground="{StaticResource White}"
                        IconColor="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/user_check.png"
                        Visibility="{Binding CanTake, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding TakeTicketCommand}" />

                    <controls:SolidButton
                        Width="160"
                        Height="40"
                        Margin="0,10,20,10"
                        FontSize="14"
                        Background="{StaticResource Orange}"
                        CornerRadius="8"
                        Text="Request info"
                        Foreground="{StaticResource White}"
                        IconColor="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/question.png"
                        Visibility="{Binding CanRequestInfo, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding RequestInfoCommand}" />

                    <controls:SolidButton
                        Width="160"
                        Height="40"
                        Margin="0,10,0,10"
                        FontSize="14"
                        Background="{StaticResource Blue}"
                        CornerRadius="8"
                        Text="Resolve"
                        Foreground="{StaticResource White}"
                        IconColor="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/checked.png"
                        Visibility="{Binding CanResolve, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding ResolveCommand}" />

                    <controls:SolidButton
                        Width="160"
                        Height="40"
                        Margin="0,10,20,10"
                        FontSize="14"
                        Background="{StaticResource Blue}"
                        CornerRadius="8"
                        Text="Reply"
                        Foreground="{StaticResource White}"
                        IconColor="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/reply.png"
                        Visibility="{Binding CanReply, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding ReplyCommand}" />

                    <controls:SolidButton
                        Width="160"
                        Height="40"
                        Margin="0,10,20,10"
                        FontSize="14"
                        Background="{StaticResource Orange}"
                        CornerRadius="8"
                        Text="Reopen"
                        Foreground="{StaticResource White}"
                        IconColor="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/undo.png"
                        Visibility="{Binding CanReopen, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding ReopenCommand}" />

                    <controls:SolidButton
                        Width="160"
                        Height="40"
                        Margin="0,10,0,10"
                        FontSize="14"
                        Background="{StaticResource Gray}"
                        CornerRadius="8"
                        Text="Close"
                        Foreground="{StaticResource White}"
                        IconColor="{StaticResource White}"
                        LeftIcon="pack://application:,,,/Resources/Icons/close.png"
                        Visibility="{Binding CanClose, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Command="{Binding CloseCommand}" />
                </WrapPanel>
            </Border>

            <Border Grid.Row="2"
                Padding="0,10,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource LightGray}">

                <Grid
                    Grid.Column="0"
                    Margin="0,0,100,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,0,5"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LightGray}"
                        Text="Info" />

                    <StackPanel
                        HorizontalAlignment="Right"
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,20,0">

                        <StackPanel.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="ID:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Created by:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Title:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Status:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Priority:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Created at:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Updated at:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Closed at:" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1">

                        <StackPanel.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsReadOnly" Value="True"/>
                                <Setter Property="IsTabStop" Value="False"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.PublicId, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.CreatedByUsername, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.Title, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.Status, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.Priority, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.CreatedAt, Mode=OneWay, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.UpdatedAt, Mode=OneWay, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentTicket.ClosedAt, Mode=OneWay, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                Padding="0,10,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource LightGray}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.Resources>
                        <Style TargetType="TextBox">
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="IsReadOnly" Value="True"/>
                            <Setter Property="IsTabStop" Value="False"/>
                        </Style>
                    </Grid.Resources>

                    <Grid Grid.Row="0"
                          Margin="0,0,0,5">
                        
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            FontSize="16"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Comments" />
                    </Grid>

                    <TextBox
                        Grid.Row="1"
                        TextWrapping="Wrap"
                        AcceptsReturn="True"
                        VerticalScrollBarVisibility="Auto"
                        MaxHeight="300"
                        FontSize="14"
                        Foreground="{StaticResource Gray}"
                        Text="{Binding CurrentTicket.Description, Mode=OneWay}" />

                    <Border
                        Grid.Row="2"
                        MinHeight="40"
                        Margin="0,10,0,0"
                        Padding="15,8,15,0"
                        CornerRadius="8"
                        BorderThickness="1"
                        Visibility="{Binding IsCommentsUpdatingOpened, Converter={StaticResource BooleanToVisibilityConverter}}"
                        BorderBrush="{StaticResource LightGray}">

                        <Grid>
                            <TextBox
                                x:Name="CommentInput"
                                Text="{Binding NewCommentText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap"
                                AcceptsReturn="True"
                                VerticalScrollBarVisibility="Auto"
                                MaxHeight="300"
                                FontSize="14"
                                Foreground="{StaticResource Gray}"
                                Background="Transparent"
                                IsReadOnly="False" 
                                IsEnabled="True" />

                            <TextBlock
                                Text="Comment text..."
                                FontSize="14"
                                Foreground="DarkGray"
                                FontStyle="Italic"
                                IsHitTestVisible="False"
                                VerticalAlignment="Top"
                                Margin="1,1,0,0">
                                
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Path=Text, ElementName=CommentInput}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>

                                            <DataTrigger Binding="{Binding Path=Text, ElementName=CommentInput}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <StackPanel
                        Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                        <controls:SolidButton
                            Width="100"
                            Height="40"
                            Margin="0,0,20,0"
                            FontSize="14"
                            Background="Transparent"
                            CornerRadius="8"
                            Text="Submit"
                            Foreground="{StaticResource Green}"
                            IconColor="{StaticResource Green}"
                            HoverBackground="{StaticResource Green}"
                            HoverForeground="{StaticResource White}"
                            HoverIconColor="{StaticResource White}"
                            BorderThickness="2"
                            BorderBrush="{StaticResource Green}"
                            LeftIcon="pack://application:,,,/Resources/Icons/checked.png"
                            Visibility="{Binding IsCommentsUpdatingOpened, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Command="{Binding SubmitCommentCommand}" />

                        <controls:SolidButton
                            Width="100"
                            Height="40"
                            FontSize="14"
                            Background="{StaticResource Gray}"
                            CornerRadius="8"
                            Text="Cancel"
                            Foreground="{StaticResource White}"
                            IconColor="{StaticResource White}"
                            LeftIcon="pack://application:,,,/Resources/Icons/close.png"
                            Visibility="{Binding IsCommentsUpdatingOpened, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Command="{Binding CancelCommentCommand}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
