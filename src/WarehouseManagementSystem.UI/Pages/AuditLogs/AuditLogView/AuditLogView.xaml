<UserControl
    x:Class="WarehouseManagementSystem.UI.Pages.AuditLogs.AuditLogView.AuditLogView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.AuditLogs.AuditLogView"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    xmlns:conv="clr-namespace:WarehouseManagementSystem.UI.Converters"
    mc:Ignorable="d"
    MinWidth="500">

    <UserControl.Resources>
        <conv:UtcToLocalConverter x:Key="UtcToLocalConverter"/>
    </UserControl.Resources>

    <Border
        Padding="20"
        CornerRadius="16"
        ClipToBounds="True"
        Background="{StaticResource White}">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                Padding="0,0,0,10">

                <TextBlock
                    HorizontalAlignment="Left"
                    Text="View Audit Log"
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{StaticResource Gray}" />
            </Border>

            <Border Grid.Row="1"
                Padding="0,10,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource LightGray}">

                <Grid
                    Grid.Column="0"
                    Margin="0,0,100,0">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,0,5"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LightGray}"
                        Text="Info" />

                    <StackPanel
                        HorizontalAlignment="Right"
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0,0,20,0">

                        <StackPanel.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="ID:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Actor name:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Actor type:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Action:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Subject ID:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Subject type:" />

                        <TextBlock
                            TextAlignment="Right"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource LightGray}"
                            Text="Created at:" />
                    </StackPanel>

                    <StackPanel
                        Grid.Row="1"
                        Grid.Column="1">

                        <StackPanel.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="IsReadOnly" Value="True"/>
                                <Setter Property="IsTabStop" Value="False"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentAuditLog.PublicId, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentAuditLog.ActorName, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentAuditLog.ActorType, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentAuditLog.Action, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentAuditLog.SubjectId, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentAuditLog.SubjectType, Mode=OneWay}" />

                        <TextBox
                            FontSize="14"
                            Foreground="{StaticResource Gray}"
                            Text="{Binding CurrentAuditLog.CreatedAt, Mode=OneWay, Converter={StaticResource UtcToLocalConverter}, StringFormat=\{0:HH:mm dd.MM.yyyy\}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                Padding="0,10,0,0"
                BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource LightGray}">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,15"
                        FontSize="16"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource LightGray}"
                        Text="Details" />

                    <ScrollViewer
                        Grid.Row="1" 
                        MaxHeight="400" 
                        VerticalScrollBarVisibility="Auto" 
                        HorizontalScrollBarVisibility="Disabled">

                        <ItemsControl
                            ItemsSource="{Binding AuditLogDetails}"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling">
                            
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid
                                        Margin="0,0,0,10">
                                        
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            TextAlignment="Right"
                                            Margin="0,0,20,0"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{StaticResource LightGray}"
                                            Text="{Binding Key, StringFormat={}{0}:}" />

                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="14"
                                            Foreground="{StaticResource Gray}"
                                            VerticalAlignment="Center"
                                            Text="{Binding Value}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
