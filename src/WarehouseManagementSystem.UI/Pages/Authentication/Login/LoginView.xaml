<UserControl
    x:Class="WarehouseManagementSystem.UI.Pages.Authentication.Login.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.Authentication.Login"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    mc:Ignorable="d"
    Background="{StaticResource White}"
    Height="400"
    Width="700">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{StaticResource Green}">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <TextBlock
                    Width="240"
                    Margin="0,0,0,40"
                    Text="WAREHOUSE MANAGEMENT SYSTEM"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource White}" />

                <Image
                    Source="pack://application:,,,/Resources/Icons/logo-box.png"
                    Width="180" 
                    Height="180" />
            </StackPanel>
        </Border>

        <StackPanel
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,0,0,40">

            <TextBlock
                HorizontalAlignment="Center"
                Text="Authentication"
                FontSize="20"
                FontWeight="Bold"
                Foreground="{StaticResource Gray}" />

            <controls:TextInput
                Width="300"
                Height="40"
                Margin="0,20,0,15"
                Placeholder="Username"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/user.png"
                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

            <controls:TextInput
                Width="300"
                Height="40"
                Margin="0,0,0,20"
                Placeholder="Password"
                IsPasswordMode="True"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/padlock.png"
                Text="{Binding Password}" />

            <controls:SolidButton
                Width="300"
                Height="40"
                FontSize="14"
                Background="{StaticResource Green}"
                CornerRadius="8"
                Text="Log in"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/login.png"
                IconColor="{StaticResource White}"
                Command="{Binding LoginCommand}"
                IsDefault="True" />

            <controls:SolidButton
                Height="22"
                Margin="0,30,0,0"
                Padding="0,0,0,2"
                HorizontalAlignment="Center"
                FontSize="14"
                Background="Transparent"
                Text="Support"
                Foreground="{StaticResource Gray}"
                Command="{Binding OpenSupportCenterAsGuestCommand}" />
        </StackPanel>
    </Grid>
</UserControl>
