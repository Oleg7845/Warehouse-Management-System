<UserControl
    x:Class="WarehouseManagementSystem.UI.Pages.Authentication.InitialAdminSetup.InitialAdminSetupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:WarehouseManagementSystem.UI.Pages.Authentication.InitialAdminSetup"
    xmlns:controls="clr-namespace:WarehouseManagementSystem.UI.Controls"
    mc:Ignorable="d"
    Background="{StaticResource White}"
    Height="400"
    Width="700">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <Border
            Grid.Column="0"
            Background="{StaticResource Green}">

            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

                <TextBlock
                    Width="240"
                    Margin="0,0,0,40"
                    Text="WAREHOUSE MANAGEMENT SYSTEM"
                    TextWrapping="Wrap"
                    TextAlignment="Center"
                    FontSize="24"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource White}" />

                <Image
                    Source="pack://application:,,,/Resources/Icons/logo-box.png"
                    Width="180" 
                    Height="180" />
            </StackPanel>
        </Border>

        <StackPanel
            Grid.Column="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Margin="0,0,0,40">

            <TextBlock
                HorizontalAlignment="Center"
                Text="Create Initial Admin"
                FontSize="20"
                FontWeight="Bold"
                Foreground="{StaticResource Gray}" />

            <controls:TextInput
                Width="300"
                Height="40"
                Margin="0,20,0,15"
                Placeholder="Username"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/user.png"
                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

            <controls:SelectInput
                Height="40"
                Margin="0,0,0,15"
                ItemsSource="{Binding AvailableRoles}"
                SelectedItem="{Binding SelectedRole}"
                Placeholder="Role"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/users.png"
                IsReadOnly="True" />

            <StackPanel
                Orientation="Horizontal"
                Margin="0,0,0,20">
                
                <controls:TextInput
                    Width="250"
                    Height="40"
                    Placeholder="Password"
                    IsPasswordMode="True"
                    LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/padlock.png"
                    Text="{Binding Password}" />

                <controls:SolidButton
                    Width="40"
                    Height="40"
                    Margin="10,0,0,0"
                    Padding="7,0,0,0"
                    FontSize="14"
                    Background="{StaticResource LightGray}"
                    CornerRadius="8"
                    Text=""
                    ToolTip="Generate password"
                    LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/refresh.png"
                    IconColor="{StaticResource White}"
                    Command="{Binding GeneratePasswordCommand}" />
            </StackPanel>

            <controls:SolidButton
                Width="300"
                Height="40"
                FontSize="14"
                Background="{StaticResource Green}"
                CornerRadius="8"
                Text="Create"
                LeftIcon="pack://application:,,,/WarehouseManagementSystem.UI;component/Resources/Icons/user_plus.png"
                IconColor="{StaticResource White}"
                Command="{Binding CreateInitialAdminCommand}"
                IsDefault="True" />
        </StackPanel>
    </Grid>
</UserControl>
